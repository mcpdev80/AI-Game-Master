        "active": { "type": "boolean" },
        "rules_text": { "type": "string" },
        "effects": {
          "type": "array",
          "items": { "$ref": "#/$defs/effectEntry" },
          "default": []
        },
        "uses_resource": { "type": ["string", "null"] },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
