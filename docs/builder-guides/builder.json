            "hp_bonus",
            "advantage",
            "disadvantage",
            "resistance",
            "immunity",
            "vulnerability",
            "proficiency",
            "expertise",
            "spell_granted",
            "spellcasting",
            "resource_grant",
            "critical_range",
            "size_change",
            "damage_bonus",
            "condition_interaction",
            "reroll",
            "movement_without_oa",
            "custom"
          ]
        },
        "target": { "type": "string" },
        "value": {},
        "condition": { "type": ["string", "null"] },
        "duration": { "type": ["string", "null"] }
      }
    },
    "resourceEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "max", "current", "recovery"],
