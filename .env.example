WEB_PORT=3005
API_PORT=8085
# Optional override. Leave empty to let build/deploy commands derive the version from ./VERSION.
APP_VERSION=
GIT_COMMIT=
BUILD_DATE=
# Local HTTPS proxy ports for LAN/device testing.
HTTPS_HTTP_PORT=3080
HTTPS_PORT=3443
# Optional file-based certificate configuration for the local HTTPS proxy.
# If both are set, scripts/generate_local_https_cert.sh will copy them into:
# - docker/certs/local-cert.pem
# - docker/certs/local-key.pem
HTTPS_CERT_FILE=
HTTPS_KEY_FILE=
# Optional defaults for self-signed generation or external-cert installation.
HTTPS_HOSTNAME=dungeon-master.local
HTTPS_HOST_IP=127.0.0.1
HTTPS_CERT_DAYS=30
API_BASE_URL=http://localhost:8085
API_INTERNAL_BASE_URL=http://api:8080
NEXT_PUBLIC_API_BASE_URL=http://localhost:8085
APP_ENV=development
DEMO_OPERATOR_SECRET=
CORS_ALLOWED_ORIGINS=http://localhost:3005,http://127.0.0.1:3005,http://localhost:13005,http://127.0.0.1:13005
TRUSTED_PROXIES=127.0.0.1,::1
PUBLIC_RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_DEMO_SEED=6
RATE_LIMIT_GM_RESPOND=30
RATE_LIMIT_STT=20
RATE_LIMIT_VISION=30
RATE_LIMIT_CHARACTER_BUILDER=20
MAX_JSON_BODY_BYTES=1048576
MAX_UPLOAD_BYTES=26214400
MAX_AUDIO_UPLOAD_BYTES=12582912
MAX_ZIP_UPLOAD_BYTES=524288000
MAX_ZIP_ENTRIES=200
MAX_ZIP_EXTRACT_BYTES=1073741824
POSTGRES_PORT=5435
POSTGRES_DB=dungeon_master
POSTGRES_USER=dungeon
POSTGRES_PASSWORD=dungeon
DATABASE_URL=postgres://dungeon:dungeon@postgres:5432/dungeon_master?sslmode=disable
# Build Week default: OpenAI Responses API. Never commit the real key.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.6
OPENAI_REASONING_EFFORT=medium
OPENAI_STORE=false
OPENAI_BUDGET_SOFT_LIMIT_USD=10
OPENAI_BUDGET_HARD_LIMIT_USD=25
OPENAI_USAGE_ALERT_EMAIL=alerts@example.com

# Optional local fallback (set LLM_PROVIDER=local).
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_MODEL=local-model
LLM_API_KEY=
# OpenAI speech defaults.
TTS_PROVIDER=openai
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=cedar
STT_PROVIDER=openai
OPENAI_STT_MODEL=gpt-4o-transcribe
OPENAI_STT_PROMPT=Tabletop role-playing game session. Preserve character names, fantasy terms, dice notation such as d20, and natural punctuation.

# Optional local speech fallbacks.
TTS_BASE_URL=http://host.docker.internal:8091/v1
TTS_MODEL=piper
TTS_API_KEY=
STT_BASE_URL=http://host.docker.internal:8092/v1
STT_MODEL=local-stt
STT_API_KEY=
UPLOADS_DIR=/tmp/data/uploads
