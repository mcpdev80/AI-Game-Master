WEB_PORT=3005
API_PORT=8085
API_BASE_URL=http://localhost:8085
API_INTERNAL_BASE_URL=http://api:8080
NEXT_PUBLIC_API_BASE_URL=http://localhost:8085
APP_ENV=development
POSTGRES_PORT=5435
POSTGRES_DB=dungeon_master
POSTGRES_USER=dungeon
POSTGRES_PASSWORD=dungeon
DATABASE_URL=postgres://dungeon:dungeon@postgres:5432/dungeon_master?sslmode=disable
# Build Week default: OpenAI Responses API. Never commit the real key.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.6
OPENAI_REASONING_EFFORT=medium
OPENAI_STORE=false

# Optional local fallback (set LLM_PROVIDER=local).
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_MODEL=local-model
LLM_API_KEY=
# OpenAI speech defaults.
TTS_PROVIDER=openai
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=cedar
STT_PROVIDER=openai
OPENAI_STT_MODEL=gpt-4o-transcribe
OPENAI_STT_PROMPT=Tabletop role-playing game session. Preserve character names, fantasy terms, dice notation such as d20, and natural punctuation.

# Optional local speech fallbacks.
TTS_BASE_URL=http://host.docker.internal:8091/v1
TTS_MODEL=piper
TTS_API_KEY=
STT_BASE_URL=http://host.docker.internal:8092/v1
STT_MODEL=local-stt
STT_API_KEY=
UPLOADS_DIR=/tmp/data/uploads
